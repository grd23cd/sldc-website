---
import type { ImageMetadata } from 'astro';

import img1 from '../assets/carousel/treeplanting-1.jpg';
import img2 from '../assets/carousel/treeplanting-2.jpg';
import img3 from '../assets/carousel/treeplanting-3.jpg';
import img4 from '../assets/carousel/treeplanting-4.jpg';
import img5 from '../assets/carousel/treeplanting-5.jpg';

const images: ImageMetadata[] = [img1, img2, img3, img4, img5];
---

<div class="tree-slider w-full h-full">

  <div class="relative w-full h-full overflow-hidden rounded-xl">

    <!-- TRACK -->
    <div class="track flex w-full h-full transition-transform duration-700 ease-in-out">
      {/* @ts-ignore */}
      {images.map((img) => (
        <img
          src={img.src}
          class="w-full h-full flex-shrink-0 object-cover"
        />
      ))}
    </div>

    <!-- BUTTONS -->
    <button class="prev absolute left-2 top-1/2 -translate-y-1/2 btn btn-circle">
      ❮
    </button>

    <button class="next absolute right-2 top-1/2 -translate-y-1/2 btn btn-circle">
      ❯
    </button>

  </div>
</div>

<script is:inline>
  const slider = document.querySelector(".tree-slider");
  const track = slider.querySelector(".track");
  const next = slider.querySelector(".next");
  const prev = slider.querySelector(".prev");

  const totalSlides = 5;
  let index = 0;

  function updateSlide() {
    track.style.transform = `translateX(-${index * 100}%)`;
  }

  let interval = setInterval(() => {
    index = (index + 1) % totalSlides;
    updateSlide();
  }, 3000);

  next.addEventListener("click", () => {
    index = (index + 1) % totalSlides;
    updateSlide();
  });

  prev.addEventListener("click", () => {
    index = (index - 1 + totalSlides) % totalSlides;
    updateSlide();
  });
</script>
