---
const { title } = Astro.props;
---

<details class="group accordion" data-accordion>
  <summary class="cursor-pointer list-none px-6 py-5 flex justify-between items-center">
    <h2 class="text-xl font-semibold">{title}</h2>

    <!-- Arrow -->
    <svg
      class="w-5 h-5 text-slate-500 transition-transform duration-300 group-open:rotate-180"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"
      />
    </svg>
  </summary>

  <div class="accordion-content px-6 pb-8 text-sm text-slate-700 space-y-3">
    <slot />
  </div>
</details>

<style>
  /* IMPORTANT: better than transition: all */
  details {
    overflow: hidden;
  }

  /* Smooth open animation fix */
  details[open] .accordion-content {
    animation: fadeIn 0.25s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* optional: remove default triangle spacing issues */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
