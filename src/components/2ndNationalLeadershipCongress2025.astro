---
import type { ImageMetadata } from 'astro';
import img1 from '../assets/carousel/2ndnationalleadershipcongress2025-1.jpg';
import img2 from '../assets/carousel/2ndnationalleadershipcongress2025-2.jpg';
import img3 from '../assets/carousel/2ndnationalleadershipcongress2025-3.jpg';
import img4 from '../assets/carousel/2ndnationalleadershipcongress2025-4.jpg';

const images: ImageMetadata[] = [img1, img2, img3, img4];
---

<div class="flex justify-center mt-10">
  <div class="relative w-[800px] h-[250px] md:h-[400px] lg:h-[500px] overflow-hidden rounded-xl shadow-lg">

    <!-- SLIDER TRACK -->
    <div id="track" class="flex w-full h-full transition-transform duration-700 ease-in-out">
    {/* @ts-ignore */}
      {images.map((img) => (
        <img src={img.src} class="w-full h-full flex-shrink-0 object-cover" />
      ))}
    </div>

    <!-- NAV BUTTONS -->
    <button id="prev"
      class="absolute left-4 top-1/2 -translate-y-1/2 btn btn-circle">
      ❮
    </button>

    <button id="next"
      class="absolute right-4 top-1/2 -translate-y-1/2 btn btn-circle">
      ❯
    </button>

  </div>
</div>