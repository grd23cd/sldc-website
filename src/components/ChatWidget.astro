---
---

<!-- FLOATING BUTTON -->
<div class="fixed bottom-6 right-6 flex flex-col items-end z-50">

  <button id="chatToggle"
    class="bg-green-700 hover:bg-green-800 text-white w-14 h-14 rounded-full flex items-center justify-center text-2xl shadow-lg">
    💬
  </button>

</div>

<!-- CHAT WINDOW -->
<div id="chatWidget"
  class="hidden fixed bottom-0 right-0 sm:bottom-24 sm:right-6 
         w-full sm:w-80 h-[85vh] sm:h-[420px]
         bg-white shadow-2xl border 
         flex flex-col z-50
         rounded-t-xl sm:rounded-xl">

  <!-- HEADER -->
  <div class="bg-green-700 text-white px-4 py-3 
              flex justify-between items-center rounded-t-xl">
    <span class="font-semibold">Chat Support</span>
    <button id="closeChat">✕</button>
  </div>

  <!-- QUICK QUESTIONS -->
  <div class="p-2 border-b flex flex-wrap gap-2 text-xs">
    <button class="quick-btn bg-gray-100 hover:bg-gray-200 px-2 py-1 rounded-md">
      What are your hours
    </button>
    <button class="quick-btn bg-gray-100 hover:bg-gray-200 px-2 py-1 rounded-md">
      Where are you located
    </button>
    <button class="quick-btn bg-gray-100 hover:bg-gray-200 px-2 py-1 rounded-md">
      How to join
    </button>
  </div>

  <!-- CHAT AREA -->
  <div id="chatBox"
    class="flex-1 overflow-y-auto space-y-2 text-sm p-2">
  </div>

</div>

<script is:inline>
  const QA = {
    "what are your hours": "We are open 8AM–5PM Monday to Friday.",
    "where are you located": "We are located in Lucban, Quezon.",
    "how to join": "Visit our membership page and fill out the form.",
  };

  const chatBox = document.getElementById("chatBox");
  const chatWidget = document.getElementById("chatWidget");
  const chatToggle = document.getElementById("chatToggle");
  const closeChat = document.getElementById("closeChat");

  function addMessage(text, type) {
    const div = document.createElement("div");

    div.className =
      type === "user"
        ? "text-right text-green-700"
        : "text-left text-gray-700";

    div.textContent = text;

    chatBox.appendChild(div);
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  function getAnswer(msg) {
    msg = msg.toLowerCase().trim();

    for (const key in QA) {
      if (msg.includes(key)) return QA[key];
    }

    return "Sorry, I don't understand that.";
  }

  function sendMessage(msg) {
    if (!msg) return;

    addMessage(msg, "user");
    addMessage(getAnswer(msg), "bot");
  }

  // Toggle open/close
  chatToggle.addEventListener("click", () => {
    chatWidget.classList.toggle("hidden");
  });

  closeChat.addEventListener("click", () => {
    chatWidget.classList.add("hidden");
  });

  // Quick buttons
  document.querySelectorAll(".quick-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      sendMessage(btn.textContent);
    });
  });
</script>
