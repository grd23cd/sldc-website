---
import type { ImageMetadata } from 'astro';
import img1 from '../assets/carousel/visitaiglesia2025-1.jpg';
import img2 from '../assets/carousel/visitaiglesia2025-2.jpg';
import img3 from '../assets/carousel/visitaiglesia2025-3.jpg';
import img4 from '../assets/carousel/visitaiglesia2025-4.jpg';
import img5 from '../assets/carousel/visitaiglesia2025-5.jpg';

const images: ImageMetadata[] = [img1, img2, img3, img4, img5];
---

<div class="slider w-full max-w-3xl aspect-square mx-auto" data-slider>
  <div class="relative w-full h-full overflow-hidden rounded-xl">

    <!-- TRACK -->
    <div class="track flex h-full transition-transform duration-700 ease-in-out">
      {/* @ts-ignore */}
      {images.map((img) => (
        <img
          src={img.src}
          class="min-w-full h-full object-cover block"
        />
      ))}
    </div>

    <!-- BUTTONS -->
    <button class="prev absolute left-2 top-1/2 -translate-y-1/2 btn btn-circle z-10">
      ❮
    </button>

    <button class="next absolute right-2 top-1/2 -translate-y-1/2 btn btn-circle z-10">
      ❯
    </button>

  </div>
</div>

<script is:inline>
  document.querySelectorAll("[data-slider]").forEach((slider) => {
    if (slider.dataset.sliderInit === "true") return;
    slider.dataset.sliderInit = "true";

    const track = slider.querySelector(".track");
    const next = slider.querySelector(".next");
    const prev = slider.querySelector(".prev");

    if (!track || !next || !prev) return;

    const slides = track.children.length;
    let index = 0;
    let interval;
    let startTimeout;

    function update() {
      track.style.transform = `translateX(-${index * 100}%)`;
    }

    function start() {
      clearTimeout(startTimeout);
      startTimeout = setTimeout(() => {
        clearInterval(interval);
        interval = setInterval(() => {
          index = (index + 1) % slides;
          update();
        }, 3000);
      }, 200);
    }

    function stop() {
      clearTimeout(startTimeout);
      clearInterval(interval);
    }

    next.addEventListener("click", () => {
      index = (index + 1) % slides;
      update();
    });

    prev.addEventListener("click", () => {
      index = (index - 1 + slides) % slides;
      update();
    });

    slider.addEventListener("mouseenter", stop);
    slider.addEventListener("mouseleave", start);

    update();
    start();
  });
</script>

