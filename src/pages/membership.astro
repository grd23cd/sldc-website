---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="max-w-6xl mx-auto px-6 py-16 space-y-12">

    <!-- HERO -->
    <section class="text-center space-y-4">
      <h1 class="text-5xl font-bold tracking-tight text-slate-900">
        HOW TO BE A MEMBER
      </h1>
    </section>

    <!-- WHAT IS COOPERATIVE -->
    <section class="grid md:grid-cols-3 gap-8 items-center">
      
      <div>
        <h2 class="text-3xl font-semibold text-slate-900">
          Ano ang Kooperatiba?
        </h2>
      </div>

      <div class="md:col-span-2 bg-white rounded-2xl shadow-md p-8 text-slate-700 leading-relaxed">
        <p>
          "Ang Kooperatiba ay nakakapagsarili at nakarehistrong asosasyon ng mga tao na mayroong pare-parehong interes na may kusang loob na nag sama-sama para makamit ang kanilang sosyal, pangkabuhayan at kulturang pangangailangan at hangarin sa pamamagitan ng paglalagak ng kaukulang capital, tumatangkilik sa mga produkto at serbisyo at tumatanggap ng patas na bahagi sa mga pananagutan at benepisyo na naaayon sa pandaigdigang prinsipyo ng kooperatiba."
        </p>
      </div>

    </section>

    <!-- BENEFITS -->
    <section class="bg-gradient-to-r from-green-900 to-green-700 text-white rounded-2xl shadow-lg p-10">
      <h2 class="text-3xl font-bold mb-6">BENEPISYO NG KASAPI</h2>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3 text-white/90">
        <p>• Loan</p>
        <p>• Patronage Refund</p>
        <p>• Dividend</p>
        <p>• Abuluyan</p>
        <p>• Care MBA</p>
        <p>• Death Assistance</p>
        <p>• Damayan sa Utang</p>
        <p>• Credit Card</p>
        <p>• Christmas Gift</p>
      </div>
    </section>

    <!-- REQUIREMENTS CARD -->
    <section class="bg-white rounded-2xl shadow-md p-8 space-y-6">

      <h2 class="text-3xl font-semibold text-slate-900">
        HALAGANG DAPAT IHANDA SA PAGSAPI
      </h2>

      <div class="divide-y divide-slate-100 text-slate-700">

        <div class="flex justify-between py-3">
          <span>Fixed Deposit</span>
          <span class="font-medium">₱1,000.00 (pinakamababa)</span>
        </div>

        <div class="flex justify-between py-3">
          <span>Membership Fee</span>
          <span class="font-medium">₱100.00</span>
        </div>

        <div class="flex justify-between py-3">
          <span>Passbook</span>
          <span class="font-medium">₱100.00</span>
        </div>

        <div class="flex justify-between py-3">
          <span>Building Fund</span>
          <span class="font-medium">₱150.00</span>
        </div>

        <div class="flex justify-between py-3">
          <span>Credit Card</span>
          <span class="font-medium">₱250.00</span>
        </div>

        <div class="flex justify-between py-3">
          <span>Application Fee</span>
          <span class="font-medium">₱50.00</span>
        </div>

        <div class="flex justify-between py-3">
          <span>ATM & Mobile Banking</span>
          <span class="font-medium">₱250.00</span>
        </div>

        <div class="flex justify-between py-3">
          <span>ID</span>
          <span class="font-medium">₱100.00</span>
        </div>

        <div class="flex justify-between py-3">
          <span>Abuluyan</span>
          <span class="font-medium">₱500.00</span>
        </div>

        <div class="flex justify-between py-3 font-semibold">
          <span>Total</span>
          <span>₱2,500.00</span>
        </div>

      </div>

      <div class="pt-6 border-t border-slate-100">
        <h3 class="text-xl font-semibold mb-3">Iba pang Insurance (optional)</h3>

        <div class="divide-y divide-slate-100 text-slate-700">

          <div class="flex justify-between py-3">
            <span>Care MBA Membership Fee</span>
            <span>₱150.00</span>
          </div>

          <div class="flex justify-between py-3">
            <span>Care MBA Contribution</span>
            <span>₱240.00 (3 buwan)</span>
          </div>

          <div class="flex justify-between py-3 font-semibold">
            <span>Total</span>
            <span>₱390.00</span>
          </div>

        </div>
      </div>

      <p class="text-sm text-slate-500 pt-4">
        NOTE: Ang minimum Fixed Deposit ng isang kasapi ay ₱4,000.00 at kailangan itong punan sa loob ng 1 taon.
      </p>

    </section>

    <!-- REQUIREMENTS -->
    <section class="bg-gradient-to-r from-green-900 to-green-700 text-white rounded-2xl shadow-lg p-10">
      <h2 class="text-3xl font-bold mb-6">MGA KAILANGAN SA PAGMIMIYEMBRO</h2>

      <div class="grid sm:grid-cols-2 gap-3 text-white/90">
        <p>• Pre-Membership Seminar</p>
        <p>• Membership Form</p>
        <p>• 2 SLDC Members Signature</p>
        <p>• Birth Certificate</p>
        <p>• Marriage Certificate (if married)</p>
        <p>• 2x2 & 1x1 Pictures</p>
        <p>• TIN Number</p>
      </div>
    </section>

  </div>
</BaseLayout>
