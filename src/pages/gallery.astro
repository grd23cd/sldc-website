---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { gallerySections as rawGallerySections } from "../data/galleryImages";
import TreePlanting from "../components/TreePlanting.astro";
import TeamBuilding2025 from "../components/TeamBuilding2025.astro";
import TrickOrTreat2025 from "../components/TrickOrTreat2025.astro";
import VisitaIglesia2025 from "../components/VisitaIglesia2025.astro";
import PhillipineChamberofCooperativesGeneralAssembly2025 from "../components/PhilippineChamberofCooperativesGeneralAssembly2025.astro";
import ProcessionFeastOfSanRafaelArkanghel2025 from "../components/ProcessionFeastOfSanRafaelArkanghel2025.astro";
import QuezonFederationAndUnionOfCooperatives2025 from "../components/QuezonFederationAndUnionOfCooperatives2025.astro";
import RealOutreach2025 from "../components/RealOutreach2025.astro";
import SldcThanksgivingParty2025 from "../components/SldcThanksgivingParty2025.astro";
import CoopMonth2025TreePlanting from "../components/CoopMonth2025TreePlanting.astro";
import IndependenceDay2025 from "../components/IndependenceDay2025.astro";
import MassFeastOfSanRafaelArkanghel2025 from "../components/MassFeastOfSanRafaelArkanghel2025.astro";

type GallerySection = {
  title: string;
  images: ImageMetadata[];
};

const gallerySections = rawGallerySections as GallerySection[];
---

<BaseLayout>
  <div class="max-w-6xl mx-auto px-6 py-16 space-y-16">

    <!-- HEADER -->
    <section class="text-center space-y-4">
      <h1 class="text-5xl font-bold tracking-tight text-slate-900">
        Gallery
      </h1>

      <p class="text-slate-500">
        Mga larawan at video ng mga kaganapan at serbisyo ng
        San Luis Development Cooperative
      </p>
    </section>

    <!-- Dynamic Image Sections -->
    {/* @ts-ignore */}
    {gallerySections.map((section: GallerySection) => (
      <section class="bg-slate-50 rounded-3xl border border-slate-200 shadow-sm p-6 md:p-8 space-y-6">

        <h2 class="text-2xl font-bold text-slate-900 text-center">
          {section.title}
        </h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {/* @ts-ignore */}
          {section.images.map((img: ImageMetadata) => (
            <div class="group rounded-2xl overflow-hidden shadow-md bg-white">
              <Image
                src={img}
                alt={section.title}
                class="w-full h-56 object-cover group-hover:scale-105 transition duration-300"
              />
            </div>
          ))}
        </div>

      </section>
    ))}

    <!-- Community Services & Activities-->
    <section class="bg-slate-50 rounded-3xl border border-slate-200 shadow-sm p-6 md:p-8 space-y-6">

      <h2 class="text-2xl font-bold text-slate-900 text-center">
        Community Services & Activities
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <div class="rounded-2xl overflow-hidden shadow-md bg-white">
          <iframe
            class="w-full aspect-video"
            src="https://www.youtube.com/embed/CxWtc3RJ4Uc"
            allowfullscreen>
          </iframe>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white">
          <iframe
            class="w-full aspect-video"
            src="https://www.youtube.com/embed/pbBh8DekdnE"
            allowfullscreen>
          </iframe>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white">
          <iframe
            class="w-full aspect-video"
            src="https://www.youtube.com/embed/ED8GkHeUOS8"
            allowfullscreen>
          </iframe>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <TreePlanting />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <TeamBuilding2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <TrickOrTreat2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <VisitaIglesia2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <PhillipineChamberofCooperativesGeneralAssembly2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <ProcessionFeastOfSanRafaelArkanghel2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <QuezonFederationAndUnionOfCooperatives2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <RealOutreach2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <SldcThanksgivingParty2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <CoopMonth2025TreePlanting />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <IndependenceDay2025 />
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md bg-white aspect-square">
          <MassFeastOfSanRafaelArkanghel2025 />
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
