---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout>
    <div class="p-10 text-center">
        <h1 class="text-5xl">Pre-Membership Seminar Luisiana</h1>

        <div class="p-6 md:p-10">
            <div class="max-w-4xl mx-auto rounded-2xl overflow-hidden shadow-lg">
            <iframe
                class="w-full aspect-video"
                src="https://www.youtube.com/embed/pbBh8DekdnE?si=BEdAzv_hZ-8Ez-pP"
                title="Pre-Membership Seminar Luisiana"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
            </iframe>
            </div>
        </div>

        <a href={`${base}services#community`} 
            class="m-10 inline-block bg-gradient-to-r from-green-900 to-green-700 hover:from-green-800 hover:to-green-600 text-white font-semibold px-8 py-3 rounded-xl shadow-md transition duration-300">
            Back To Services
        </a>

    </div>
</BaseLayout>