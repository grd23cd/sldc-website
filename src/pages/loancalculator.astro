---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <div class="min-h-[60vh] flex items-center justify-center px-6">
    <div class="w-full max-w-md text-center space-y-8 p-8 bg-white rounded-2xl shadow-lg border border-slate-200">

      <h2 class="text-4xl font-bold text-slate-800">
        Choose a Loan Type
      </h2>

      <p class="text-slate-500 text-sm">
        Select the type of loan you want to calculate.
      </p>

      <a
        href={`${base}regularloan`}
        class="inline-block w-full py-3 px-5 rounded-xl bg-green-600 text-white font-semibold
               hover:bg-green-700 active:scale-[0.98] transition"
      >
        Regular Loan
      </a>

    </div>
  </div>
</BaseLayout>
